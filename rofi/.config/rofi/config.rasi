configuration {
  modes: "drun,run,window,power,filebrowser";
  no-default-theme: true;
  window-format: "{t}";
  terminal: "foot";
  me-select-entry: "";
  me-accept-entry: "!MousePrimary";
  hover-select: true;
  drun-display-format: "{name}";
  drun {
    display-name: "App";
    show-icons: false;
  }
  run {
    display-name: "Run";
    show-icons: false;
  }
  window {
    display-name: "Windows";
    show-icons: false;
  }
  power {
    display-name: "Power";
    show-icons: false;
  }
  filebrowser {
    display-name: "Files";
    icon-theme: "breeze-dark";
    theme: "~/.config/rofi/themes/wallpaper.rasi";
  }
}

@theme "~/.config/rofi/themes/dmenu-vertical.rasi"
